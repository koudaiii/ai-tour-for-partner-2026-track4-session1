#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${ROOT_DIR}"

usage() {
  cat <<'USAGE'
Usage: script/test [pytest options...]

Run local tests with the same setup style as GitHub Actions.
- Installs dependencies: uv sync --group dev --frozen
- Runs tests:          uv run --group dev pytest -q
USAGE
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

require_cmd() {
  local cmd="$1"
  if ! command -v "${cmd}" >/dev/null 2>&1; then
    echo "Error: '${cmd}' is required but not installed." >&2
    exit 1
  fi
}

log() {
  echo "[test] $*"
}

require_cmd uv

log "Installing dependencies (uv sync --group dev --frozen)"
uv sync --group dev --frozen

log "Running tests (uv run --group dev pytest -q $*)"
exec uv run --group dev pytest -q "$@"
